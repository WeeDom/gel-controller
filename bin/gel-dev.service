[Unit]
Description=GEL Controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=weedom
WorkingDirectory=/home/weedom/gel-controller
ExecStart=/home/weedom/gel-controller/venv/bin/python gel.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
