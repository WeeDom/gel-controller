This the uname/pass for the internal network. See README for full explanation

wifi_ssid: ssid in quotes
wifi_password: password in quotes

# Optional camera auth settings used by controller when talking to ESP32 camera endpoints.
# Must match the firmware constants in esp32cam/CameraWebServer/app_httpd.cpp
gel_controller_id: "gel-controller-1"
gel_camera_auth_secret: "change-me-camera-auth-secret"

# Optional: Manually configure presence sensors if they're not discoverable via mDNS
# presence_sensors:
#   - name: "Living Room Sensor"
#     host: "192.168.1.189"
#     port: 6053
#   - name: "Bedroom Sensor"
#     host: "192.168.1.190"
#     port: 6053
