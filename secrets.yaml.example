This the uname/pass for the internal network. See README for full explanation

wifi_ssid: ssid in quotes
wifi_password: password in quotes

# Optional camera auth settings used by controller when talking to ESP32 camera endpoints.
# Must match the firmware constants in esp32cam/CameraWebServer/app_httpd.cpp
gel_controller_id: "gel-controller-1"
gel_camera_auth_secret: "change-me-camera-auth-secret"

# Optional: Manually configure presence sensors if they're not discoverable via mDNS
# presence_sensors:
#   - name: "Living Room Sensor"
#     host: "192.168.1.189"
#     port: 6053
#   - name: "Bedroom Sensor"
#     host: "192.168.1.190"
#     port: 6053

# --- Cloud registration (guard-e-loo.co.uk CNC) ---
# Set these to enable the controller to phone home and request a reverse tunnel.
# GEL_HOME_URL must be set in .env (not here, as it's not ESPHome config).
# Add the following to your .env file:
#
#   GEL_HOME_URL=https://guard-e-loo.co.uk
#   GEL_ENROLLMENT_TOKEN=<token from the GEL admin — treat like a password>
#
# On first run the controller will POST its SSH public key and wait for an
# admin to approve the registration in the Fleet UI.  Once approved, the
# assigned tunnel port is written to /etc/gel-controller/tunnel.env and the
# gel-reverse-tunnel service is restarted automatically.
